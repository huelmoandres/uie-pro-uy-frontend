{
  "expo": {
    "name": "IUE Pro Uy",
    "slug": "iue-pro-uy",
    "version": "1.2.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "expedientes",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "updates": {
      "url": "https://u.expo.dev/5ee9cf89-f51b-4f58-a0a8-ed55408bb674",
      "fallbackToCacheTimeout": 3000,
      "checkOnLaunch": "ALWAYS",
      "enabled": true
    },
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.iueprouy.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E3A5F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.iueprouy.app",
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "notification": {
      "icon": "./assets/images/notification-icon.png",
      "color": "#1E3A5F",
      "androidMode": "default"
    },
    "plugins": [
      [
        "expo-screen-orientation",
        { "initialOrientation": "PORTRAIT" }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": ["en", "es"],
            "android": ["en", "es"]
          }
        }
      ],
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1E3A5F"
        }
      ],
      "expo-image",
      "expo-sharing",
      "expo-mail-composer",
      [
        "expo-calendar",
        {
          "calendarPermission": "La app necesita acceso al calendario para guardar fechas procesales."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Usá Face ID para acceder de forma segura a tus expedientes."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5ee9cf89-f51b-4f58-a0a8-ed55408bb674"
      }
    }
  }
}
