# =============================================================================
# IUE Pro Uy — Variables de entorno (frontend)
# =============================================================================
# Crear .env.development y .env.production desde este archivo:
#   cp .env.example .env.development
#   cp .env.example .env.production
# Luego editar cada uno con los valores correctos.
#
# Para EAS Build: subir variables al entorno correspondiente:
#   eas env:push development --path .env.development
#   eas env:push production --path .env.production
#
# Todas las variables usadas en código RN deben usar prefijo EXPO_PUBLIC_
# =============================================================================

# Entorno: development | production (determina bundle ID y nombre de app)
APP_ENV=development

# API Backend
EXPO_PUBLIC_API_URL=https://api.iueprouy.com

# RevenueCat (keys públicas en App Store Connect / Google Play Console)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_xxx
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_xxx

# Freemium (cupo gratuito de expedientes activos)
EXPO_PUBLIC_FREE_EXPEDIENTES_LIMIT=1

# Desactiva SUBSCRIPTION_BYPASS_EMAILS (probar freemium con tu email de tester)
# EXPO_PUBLIC_DISABLE_SUBSCRIPTION_BYPASS=1
# PostHog Analytics (frontend)
# API Key pública del proyecto. Obtener en: https://eu.posthog.com/settings/project
# Si no está configurado, PostHogProvider renderiza los children sin instrumentación.
EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Host de PostHog. Default: EU cloud.
# EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

